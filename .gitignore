# macOS Finder metadata
.DS_Store
**/.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/
.pytest_cache/

# Editor / IDE
*.swp
*.swo
.vscode/
.idea/

# Game ISOs (users must provide their own)
iso/*.iso

# xdvdfs cache (auto-downloaded on first use — user-specific)
tools/xdvdfs
tools/xdvdfs.exe

# Extracted save data (user-specific; may contain personal saves)
scripts/save_data/
scripts/save*_extracted/
save_data/
save*_extracted/
*.qcow2
# Xbox EEPROM dumps carry per-console identity material — don't
# commit user EEPROMs even when pulled in for signature research.
eeprom.bin
*.eeprom

# Extracted game audio (users must provide their own ISO; these are
# tool OUTPUT directories, not source).  ``audio dump`` emits a lot
# of .bin/.wav files + a manifest.json under the target dir; guard
# against accidental commits of derived game content.
audio_out/
Azurik Audio/
**/audio_out/
**/Azurik Audio/
**/waves/
